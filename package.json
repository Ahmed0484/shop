{
  "name": "shop",
  "version": "1.0.0",
  "description": "eCommerce built with MERN stack",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node backend/server.js",
    "server": "nodemon backend/server.js",
    "client": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "data:import": "node backend/seeder",
    "data:destroy": "node backend/seeder -d"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ahmed0484/shop.git"
  },
  "author": "Ahmed El-Shazly",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Ahmed0484/shop/issues"
  },
  "homepage": "https://github.com/Ahmed0484/shop#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "colors": "^1.4.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "nodemon": "^3.1.14"
  }
}
